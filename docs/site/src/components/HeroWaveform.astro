---
// animated waveform visualization in the hero area
---

<div class="hero-waveform" aria-hidden="true">
  <svg viewBox="0 0 120 40" preserveAspectRatio="none" class="waveform-svg">
    <rect class="bar" x="2" y="12" width="3" rx="1.5" />
    <rect class="bar" x="8" y="8" width="3" rx="1.5" />
    <rect class="bar" x="14" y="14" width="3" rx="1.5" />
    <rect class="bar" x="20" y="4" width="3" rx="1.5" />
    <rect class="bar" x="26" y="10" width="3" rx="1.5" />
    <rect class="bar" x="32" y="6" width="3" rx="1.5" />
    <rect class="bar" x="38" y="16" width="3" rx="1.5" />
    <rect class="bar" x="44" y="2" width="3" rx="1.5" />
    <rect class="bar" x="50" y="10" width="3" rx="1.5" />
    <rect class="bar" x="56" y="6" width="3" rx="1.5" />
    <rect class="bar" x="62" y="14" width="3" rx="1.5" />
    <rect class="bar" x="68" y="8" width="3" rx="1.5" />
    <rect class="bar" x="74" y="12" width="3" rx="1.5" />
    <rect class="bar" x="80" y="4" width="3" rx="1.5" />
    <rect class="bar" x="86" y="10" width="3" rx="1.5" />
    <rect class="bar" x="92" y="16" width="3" rx="1.5" />
    <rect class="bar" x="98" y="6" width="3" rx="1.5" />
    <rect class="bar" x="104" y="12" width="3" rx="1.5" />
    <rect class="bar" x="110" y="8" width="3" rx="1.5" />
    <rect class="bar" x="116" y="14" width="3" rx="1.5" />
  </svg>
</div>

<style>
  .hero-waveform {
    position: absolute;
    top: 2rem;
    right: 2rem;
    width: 12rem;
    height: 5rem;
    opacity: 0.25;
    pointer-events: none;
  }

  .waveform-svg {
    width: 100%;
    height: 100%;
  }

  .bar {
    fill: var(--sl-color-accent);
    height: 20px;
    animation: pulse 2s ease-in-out infinite alternate;
  }

  .bar:nth-child(2n) { animation-delay: 0.2s; }
  .bar:nth-child(3n) { animation-delay: 0.4s; }
  .bar:nth-child(4n) { animation-delay: 0.6s; }
  .bar:nth-child(5n) { animation-delay: 0.8s; }

  @keyframes pulse {
    0% { opacity: 0.4; transform: scaleY(0.6); }
    100% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero-waveform {
      display: none;
    }
  }
</style>
