# docs site commands

# install dependencies
install:
    bun install

# start dev server
run: install
    bun run dev

# build static site
build: install
    bun run build

# preview built site
preview: install
    bun run preview

# regenerate API reference from backend source
api-ref:
    rm -rf ../public/developers/api-reference
    cd ../../backend && uv run --with mdxify mdxify \
        --all \
        --root-module backend.api \
        --format md \
        --output-dir ../docs/public/developers/api-reference \
        --no-update-nav \
        --exclude backend.api.tracks.services \
        --exclude backend.api.tracks.constants \
        --exclude backend.api.tracks.router \
        --exclude backend.api.migration \
        --exclude backend.api.pds_backfill
    # strip backend-api- prefix, nest tracks subpackage
    cd ../public/developers/api-reference && \
        for f in backend-api-*.md; do mv "$f" "${f#backend-api-}"; done && \
        mkdir -p tracks && \
        for f in tracks-*.md; do mv "$f" "tracks/${f#tracks-}"; done && \
        mv tracks/__init__.md tracks/overview.md
