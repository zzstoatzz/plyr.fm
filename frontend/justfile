set shell := ["bash", "-eu", "-o", "pipefail", "-c"]
default := "run"

alias r := run
alias dev := run

# run frontend dev server (hot reloads)
run:
    bun run dev --host 0.0.0.0

# check svelte types
check:
    bun run check

# run component tests (jsdom, fast — no browser)
test:
    bun run test

# accessibility gate: render every story in chromium, fail on axe violations
# (needs `bunx playwright install chromium` once)
test-storybook:
    PUBLIC_API_URL="${PUBLIC_API_URL:-https://api.plyr.fm}" bun run test-storybook

# preview components in isolation (storybook, http://localhost:6006)
storybook:
    bun run storybook

# build the static storybook (used to sanity-check stories in CI)
build-storybook:
    PUBLIC_API_URL="${PUBLIC_API_URL:-https://api.plyr.fm}" bun run build-storybook
